    <!-- 电池厂商提示 -->
    <string name="battery_tip_allow_background">请确认在应用设置→电池中已启用"允许后台运行"。</string>
    <string name="battery_tip_battery_saver">若使用"省电模式"，请将 RADE Decode 加入例外列表。</string>
    <string name="battery_tip_samsung_1">Samsung：设置→电池→后台使用限制→永不休眠的应用→添加 RADE Decode。</string>
    <string name="battery_tip_samsung_2">Samsung：停用"自适应电池"或将应用加入"未受监控的应用"。</string>
    <string name="battery_tip_samsung_3">Samsung：设置→应用→RADE Decode→电池→不受限制。</string>
    <string name="battery_tip_xiaomi_1">小米/POCO：设置→应用→RADE Decode→省电策略→无限制。</string>
    <string name="battery_tip_xiaomi_2">小米/POCO：设置→电池→应用省电→RADE Decode→无限制。</string>
    <string name="battery_tip_xiaomi_3">小米/POCO：安全中心→电池→应用省电→RADE Decode→无限制。</string>
    <string name="battery_tip_xiaomi_4">小米/POCO：在安全设置中为 RADE Decode 启用"自启动"。</string>
    <string name="battery_tip_huawei_1">华为/荣耀：设置→电池→应用启动管理→RADE Decode→设为"手动管理"并启用所有选项。</string>
    <string name="battery_tip_huawei_2">华为/荣耀：设置→应用→RADE Decode→电池→启用"允许后台运行"。</string>
    <string name="battery_tip_huawei_3">华为/荣耀：停用此应用的"高耗电提醒"。</string>
    <string name="battery_tip_oppo_1">OPPO/Realme/OnePlus：设置→电池→更多设置→优化电池用量→RADE Decode→不要优化。</string>
    <string name="battery_tip_oppo_2">OnePlus：设置→电池→电池优化→RADE Decode→不要优化。</string>
    <string name="battery_tip_oppo_3">OPPO/Realme：启用"允许自启动"和"允许后台运行"。</string>
    <string name="battery_tip_vivo_1">vivo/iQOO：设置→电池→后台耗电管理→RADE Decode→允许。</string>
    <string name="battery_tip_vivo_2">vivo/iQOO：i 管家→应用管理→自启动管理→启用 RADE Decode。</string>
    <string name="battery_tip_asus">ASUS：设置→电池→PowerMaster→自启动管理→启用 RADE Decode。</string>
    <string name="battery_tip_sony">Sony：设置→电池→自适应电池→例外→添加 RADE Decode。</string>

