    <!-- Battery Optimization Dialog -->
    <string name="battery_dialog_title">Background Decoding Setup</string>
    <string name="battery_dialog_description">RADE Decode needs to run in the background to continuously receive and decode signals. Some devices restrict background activity which may interrupt decoding.</string>
    <string name="battery_opt_disabled">Battery optimization is disabled — good!</string>
    <string name="battery_opt_enabled">Battery optimization is enabled — may interrupt decoding</string>
